@startuml SD01_Dang_Nhap
' ============================================
' DIAGRAM 1: ĐĂNG NHẬP (LOGIN)
' ============================================
title SD01: Luồng Đăng nhập

actor "User" as U
participant "LoginForm" as LF
participant "DatabaseHelper" as DH
participant "BCrypt" as BC
participant "UserSession" as US
database "SQL Server" as DB
participant "Dashboard" as D

U -> LF: Nhập username, password
activate LF
U -> LF: Click "Đăng nhập"

alt Validation thất bại
    LF -> LF: Kiểm tra input rỗng
    LF --> U: ToastNotification.Warning\n("Vui lòng nhập...")
else Validation thành công
    LF -> DH: AuthenticateUser(username, password)
    activate DH
    
    DH -> DB: SELECT * FROM users\nWHERE username = @username
    DB --> DH: DataRow user

    alt User không tồn tại
        DH --> LF: return null
        LF --> U: ToastNotification.Error\n("Sai thông tin!")
    else User tồn tại
        DH -> BC: BCrypt.Verify(password, storedHash)
        BC --> DH: true/false
        
        alt Mật khẩu sai
            DH --> LF: return null
            LF --> U: ToastNotification.Error\n("Sai thông tin!")
        else Mật khẩu đúng
            DH --> LF: return DataRow user
            deactivate DH
            
            alt Tài khoản bị khóa (is_active = false)
                LF --> U: ToastNotification.Error\n("Tài khoản đã bị khóa!")
            else Tài khoản active
                LF -> US: Gán UserId, Username,\nFullName, Email, Role, LoginTime
                
                LF -> DH: UpdateLastLogin(UserId)
                activate DH
                DH -> DB: UPDATE users SET\nlast_login = GETDATE()
                deactivate DH
                
                LF -> LF: DialogResult = OK
                LF -> LF: Close()
                deactivate LF
                
                create D
                LF --> D: new Dashboard()
                activate D
                D -> DH: GetDocumentsForCurrentUser()
                activate DH
                DH -> DB: SELECT * FROM tai_lieu\nWHERE user_id = @userId
                DB --> DH: DataTable
                deactivate DH
                D --> U: Hiển thị Dashboard
                deactivate D
            end
        end
    end
end
@enduml


@startuml SD02_Them_Tai_Lieu
' ============================================
' DIAGRAM 3: THÊM TÀI LIỆU
' ============================================
title SD03: Luồng Thêm tài liệu mới

actor "User" as U
participant "Dashboard" as D
participant "AddEditForm" as AE
participant "OpenFileDialog" as OFD
participant "DatabaseHelper" as DH
participant "UserSession" as US
database "SQL Server" as DB

U -> D: Click "Thêm" (Ctrl+N)
activate D
D -> AE: new AddEditForm()
activate AE
AE -> AE: LoadComboBoxData()
D -> AE: ShowDialog()
deactivate D

U -> AE: Click "Chọn file"
AE -> OFD: ShowDialog()
activate OFD
U -> OFD: Chọn file
OFD --> AE: filePath
deactivate OFD

AE -> AE: Tự động điền:\n- Tên file\n- Kích thước (MB)

U -> AE: Nhập: Danh mục, Loại,\nGhi chú, Tác giả, Tags, Deadline
U -> AE: Click "Lưu"

AE -> AE: Validate()

alt Validation thất bại
    AE --> U: ToastNotification.Warning\n(lỗi tương ứng)
else Validation OK
    AE -> DH: InsertDocument(ten, mon_hoc,\nloai, duong_dan, ghi_chu,\nkich_thuoc, tac_gia, quan_trong,\ntags, deadline)
    activate DH
    
    DH -> US: UserSession.UserId
    US --> DH: userId
    
    DH -> DB: INSERT INTO tai_lieu\n(..., user_id = @userId)
    DB --> DH: rows affected
    DH --> AE: true/false
    deactivate DH
    
    alt Thành công
        AE --> U: ToastNotification.Success\n("Thêm thành công!")
        AE -> AE: DialogResult = OK
        AE -> AE: Close()
        deactivate AE
        
        activate D
        D -> D: LoadData()
        D -> DH: GetDocumentsForCurrentUser()
        activate DH
        DH -> DB: SELECT * FROM tai_lieu\nWHERE user_id = @userId
        DH --> D: DataTable
        deactivate DH
        D --> U: Refresh danh sách
        deactivate D
    else Thất bại
        AE --> U: ToastNotification.Error\n("Lỗi khi lưu!")
    end
end
@enduml


@startuml STATE_Tai_Lieu
' ============================================
' BIỂU ĐỒ TRẠNG THÁI: QUẢN LÝ TÀI LIỆU
' ============================================
title Biểu đồ trạng thái: Vòng đời Tài liệu

[*] --> ChuaLuu : User mở form\nThêm tài liệu

state "Chưa lưu" as ChuaLuu {
    [*] --> NhapThongTin
    NhapThongTin : Nhập tên, danh mục, loại
    NhapThongTin --> ChonFile : Click "Chọn file"
    ChonFile : Chọn file từ máy tính
    ChonFile --> DaChonFile : File hợp lệ
    ChonFile --> NhapThongTin : Hủy chọn
    DaChonFile : Tự động điền tên, kích thước
    DaChonFile --> NhapThongTin : Nhập thêm thông tin
}

ChuaLuu --> DaLuu : Click "Lưu"\n[Validation OK]
ChuaLuu --> [*] : Click "Hủy"

state "Đã lưu" as DaLuu {
    [*] --> BinhThuong
    
    state "Bình thường" as BinhThuong
    state "Quan trọng" as QuanTrong
    state "Sắp đến hạn" as SapDenHan
    state "Quá hạn" as QuaHan
    
    BinhThuong : quan_trong = false
    BinhThuong : deadline = NULL hoặc > 7 ngày
    
    QuanTrong : quan_trong = true
    
    SapDenHan : deadline trong 7 ngày tới
    SapDenHan : Hiển thị màu vàng/cam
    
    QuaHan : deadline < ngày hiện tại
    QuaHan : Hiển thị màu đỏ
    
    BinhThuong --> QuanTrong : Đánh dấu\nquan trọng
    QuanTrong --> BinhThuong : Bỏ đánh dấu\nquan trọng
    
    BinhThuong --> SapDenHan : Thời gian\ntrôi qua
    SapDenHan --> QuaHan : Hết hạn
    
    QuanTrong --> SapDenHan : Thời gian\ntrôi qua
}

DaLuu --> DangSua : Click "Sửa"

state "Đang sửa" as DangSua {
    [*] --> ChinhSuaThongTin
    ChinhSuaThongTin : Sửa tên, danh mục, loại,\nghi chú, tags, deadline
    ChinhSuaThongTin --> DoiFile : Chọn file mới
    DoiFile --> ChinhSuaThongTin : File đã đổi
}

DangSua --> DaLuu : Click "Lưu"\n[Cập nhật thành công]
DangSua --> DaLuu : Click "Hủy"\n[Không lưu thay đổi]

DaLuu --> XacNhanXoa : Click "Xóa"

state "Xác nhận xóa" as XacNhanXoa {
    [*] --> HoiXacNhan
    HoiXacNhan : "Bạn có chắc chắn\nmuốn xóa?"
}

XacNhanXoa --> DaLuu : Click "Không"
XacNhanXoa --> DaXoa : Click "Có"

state "Đã xóa" as DaXoa
DaXoa --> [*] : Xóa khỏi database

note right of ChuaLuu
  Form AddEditForm
  Mode: Thêm mới
end note

note right of DangSua
  Form AddEditForm
  Mode: Chỉnh sửa
end note

note bottom of DaLuu
  Tài liệu được lưu trong database
  với user_id = UserSession.UserId
end note

@enduml


@startuml ACT_Tim_Kiem_Loc
' ============================================
' BIỂU ĐỒ HOẠT ĐỘNG: TÌM KIẾM VÀ LỌC TÀI LIỆU
' ============================================
title Biểu đồ hoạt động: Tìm kiếm và Lọc tài liệu

|User|
start
:Mở Dashboard;

|System|
:Load danh sách tài liệu\ncủa user hiện tại;
:Hiển thị DataGridView;

|User|
:Xem danh sách tài liệu;

if (Muốn tìm kiếm/lọc?) then (Có)
    
    fork
        :Nhập từ khóa\nvào ô tìm kiếm;
    fork again
        :Chọn Danh mục\ntừ ComboBox;
    fork again
        :Chọn Loại tài liệu\ntừ ComboBox;
    fork again
        if (Bật filter nâng cao?) then (Có)
            :Chọn khoảng ngày\n(Từ ngày - Đến ngày);
            :Chọn khoảng dung lượng\n(Min - Max MB);
            :Tick "Chỉ tài liệu quan trọng";
        else (Không)
        endif
    end fork
    
    |User|
    :Click "Tìm kiếm" hoặc\n"Áp dụng Filter";
    
    |System|
    :Thu thập các điều kiện lọc;
    
    :Gọi SearchDocumentsAdvanced();
    
    partition "Xây dựng Query" {
        :Khởi tạo base query\nSELECT * FROM tai_lieu\nWHERE user_id = @userId;
        
        if (Có từ khóa?) then (Có)
            :Thêm điều kiện\nAND (ten LIKE @keyword\nOR ghi_chu LIKE @keyword\nOR tags LIKE @keyword);
        else (Không)
        endif
        
        if (Danh mục != "Tất cả"?) then (Có)
            :Thêm điều kiện\nAND mon_hoc = @mon_hoc;
        else (Không)
        endif
        
        if (Loại != "Tất cả"?) then (Có)
            :Thêm điều kiện\nAND loai = @loai;
        else (Không)
        endif
        
        if (Filter ngày được bật?) then (Có)
            :Thêm điều kiện\nAND ngay_them >= @fromDate\nAND ngay_them <= @toDate;
        else (Không)
        endif
        
        if (Filter dung lượng được bật?) then (Có)
            :Thêm điều kiện\nAND kich_thuoc >= @minSize\nAND kich_thuoc <= @maxSize;
        else (Không)
        endif
        
        if (Chỉ quan trọng?) then (Có)
            :Thêm điều kiện\nAND quan_trong = 1;
        else (Không)
        endif
        
        :Thêm ORDER BY\nngay_them DESC;
    }
    
    :Thực thi query\nvào SQL Server;
    
    :Nhận DataTable kết quả;
    
    :Bind DataTable vào\nDataGridView;
    
    :Cập nhật lblCount\n"Tìm thấy: X tài liệu";
    
    |User|
    if (Có kết quả?) then (Có)
        :Xem danh sách\nkết quả tìm kiếm;
        
        if (Muốn mở tài liệu?) then (Có)
            :Double-click hoặc\nclick "Mở file";
            
            |System|
            if (File tồn tại?) then (Có)
                :Process.Start(duong_dan);
                :Mở file bằng\nứng dụng mặc định;
            else (Không)
                :Hiển thị lỗi\n"File không tồn tại!";
            endif
        else (Không)
        endif
        
        |User|
        if (Muốn xóa filter?) then (Có)
            :Click "Xóa Filter";
            
            |System|
            :Reset tất cả điều kiện\nvề mặc định;
            :Load lại toàn bộ\ntài liệu của user;
        else (Không)
        endif
        
    else (Không có)
        |System|
        :Hiển thị DataGridView trống;
        :lblCount = "Tìm thấy: 0 tài liệu";
        
        |User|
        :Thử điều kiện khác\nhoặc xóa filter;
    endif
    
else (Không)
    |User|
    :Làm việc với\ndanh sách hiện tại;
endif

stop

@enduml
